{
  "manifest_version": 3,
  "name": "Hover Translator",
  "version": "1.0.4",
  "description": "Instant word translations on hover. Freemium: 100 words/day free, unlimited with Premium.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Hover Translator"
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.mymemory.translated.net/*",
    "https://api.dictionaryapi.dev/*",
    "https://libretranslate.com/*",
    "https://libretranslate.de/*",
    "https://*/*"
  ]
}